4)UDP(image transfer)
SERVER:
import socket
HOST = "0.0.0.0"
PORT = 5005
BUFFER_SIZE = 4096
END_MARKER = b"__END__"
sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
sock.bind((HOST, PORT))
print("UDP Image Server started... Waiting for image...")
image_data = b""
while True:
 data, addr = sock.recvfrom(BUFFER_SIZE)
 if data == END_MARKER:
 break
 image_data += data
with open("received_image.jpg", "wb") as f:
 f.write(image_data)
print("Image received and saved successfully.")
sock.close()


