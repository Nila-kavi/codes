import socket
HOST = '0.0.0.0'
PORT = 5000
def run_server():
 server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
 server.bind((HOST, PORT))
 server.listen(1)
 print(f"TCP chat server running on port {PORT}...")
 dictionary = {
 "lab": "A place for practical experiments",
 "cloud": "Internet-based computing resources",
 "network": "Interconnection of computers"
 }
 conn, addr = server.accept()
 print("Client connected:", addr)
 while True:
 word = conn.recv(1024).decode()
 if not word or word.lower() == "exit":
 print("Client disconnected.")
 break
 print("Client:", word)
 if word in dictionary:
 reply = dictionary[word]
 else:
 reply = "Word not found"
 conn.send(reply.encode())
 if reply.lower() == "exit":
 break
 conn.close()
 server.close()
if __name__ == "__main__":
 run_server()

