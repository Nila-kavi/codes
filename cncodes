import ast 
def dls(tree, node, goal, depth, path): 
    path = path + [node] 
    if node == goal: 
        return path 
    if depth == 0: 
        return None 
    for child in tree.get(node, []): 
        if child not in path: 
            result = dls(tree, child, goal, depth - 1, path) 
            if result: 
                return result 
    return None 
def ids(tree, start, goal, step=1, max_depth=50): 
    depth = step 
    while depth <= max_depth: 
        path = dls(tree, start, goal, depth, []) 
        print(f"Depth {depth}:", path) 
        if path: 
            return path 
        depth += step 
    return None 
