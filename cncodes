import ast 
def alphabeta(node, maximizingPlayer, alpha, beta, level=0): 
    if isinstance(node, int): 
        return node 
    values = []          # Store child values 
    pruned_flag = False  # Track pruning 
    if maximizingPlayer: 
        maxEval = float('-inf') 
        for child in node: 
            if pruned_flag: 
                values.append("pruned") 
                continue 
            eval_child = alphabeta(child, False, alpha, beta, level + 1) 
            values.append(eval_child) 
            if eval_child > maxEval: 
                maxEval = eval_child 
            alpha = max(alpha, eval_child) 
            if beta <= alpha: 
                pruned_flag = True 
        print(f"Max node at level {level}: {values} -> {maxEval}") 
        return maxEval 
    else: 
        minEval = float('inf') 
        for child in node: 
            if pruned_flag: 
                values.append("pruned") 
                continue 
            eval_child = alphabeta(child, True, alpha, beta, level + 1) 
            values.append(eval_child) 
            if eval_child < minEval: 
                minEval = eval_child 
            beta = min(beta, eval_child) 
            if beta <= alpha: 
                pruned_flag = True 
        print(f"Min node at level {level}: {values} -> {minEval}") 
        return minEval 
