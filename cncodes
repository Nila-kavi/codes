def a_star(graph, start, goal, heuristic, cost=None): 
    queue = [(heuristic[start], 0, [start])] 
    visited = set() 
    while queue: 
        f_val, g_val, path = heapq.heappop(queue) 
        node = path[-1] 
        if node == goal: 
            return path, g_val 
        if node not in visited: 
            visited.add(node) 
            print(f"Expanding node {node} with g={g_val}, h={heuristic[node]}, f={f_val}") 
            if node in graph: 
                for neighbor, edge_cost in graph[node].items(): 
                    if neighbor not in visited: 
                        g_new = g_val + edge_cost 
                        f_new = g_new + heuristic[neighbor] 
                        heapq.heappush(queue, (f_new, g_new, path + [neighbor])) 
    return None, None 
