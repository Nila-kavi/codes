import heapq 
def water_jug_a_star(cap1, cap2, target_jug, target_amount): 
    start = (0, 0) 
    pq = [] 
    heapq.heappush(pq, (0, 0, start, [])) 
    visited = set() 
    def heuristic(state): 
        if target_jug == 1: 
            return abs(state[0] - target_amount) 
        else: 
            return abs(state[1] - target_amount) 
    while pq: 
        f, g, (x, y), path = heapq.heappop(pq) 
        if (x, y) in visited: 
            continue 
        visited.add((x, y)) 
        path = path + [(x, y)] 
        if (target_jug == 1 and x == target_amount) or\
           (target_jug == 2 and y == target_amount): 
            return path 
        successors = [ 
            (0, y),          # Empty jug1 
            (x, 0),          # Empty jug2 
            (cap1, y),       # Fill jug1 
            (x, cap2)        # Fill jug2 
        ] 
        transfer = min(x, cap2 - y) 
        successors.append((x - transfer, y + transfer)) 
        transfer = min(y, cap1 - x) 
        successors.append((x + transfer, y - transfer)) 
        for state in successors: 
            if state not in visited: 
                new_g = g + 1 
                new_f = new_g + heuristic(state) 
                heapq.heappush(pq, (new_f, new_g, state, path)) 
    return None 
