from collections import deque
def bfs(graph, start):
    visited = set()
    queue = deque([start])
    traversal = []
    visited.add(start)
    while queue:
        node = queue.popleft()
        traversal.append(node)
        for neighbor in graph[node]:
            if neighbor not in visited:
                visited.add(neighbor)
                queue.append(neighbor)
    return traversal
