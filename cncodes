import socket
import random
import sys
HOST = "127.0.0.1"
PORT = 30000
try:
 sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
 sock.bind((HOST, PORT))
except OSError as e:
 print("Socket bind failed:", e)
 print("Close IDLE completely and run again.")
 sys.exit(1)
print("UDP Guess-It Server Started on port", PORT)
magic = random.randint(1, 100)
attempts = 0
try:
 while attempts < 10:
 data, addr = sock.recvfrom(1024)
 guess = int(data.decode())
 if guess < 1 or guess > 100:
 sock.sendto(
 b"Invalid guess! Enter a number between 1 and 100",
 addr
 )
 continue
 attempts += 1
 if guess < magic:
 sock.sendto(b"Higher", addr)
 elif guess > magic:
 sock.sendto(b"Lower", addr)
else:
 sock.sendto(b"Great", addr)
 break
 if attempts == 10:
 sock.sendto(b"Better luck next time :)", addr)
except KeyboardInterrupt:
 print("\nServer stopped by user")
finally:
 sock.close()
 print("Socket closed cleanly")

